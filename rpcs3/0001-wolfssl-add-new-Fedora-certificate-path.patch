From 879a4a47029bf83103b98114015a356f98c6339a Mon Sep 17 00:00:00 2001
From: Phantom X <PhantomX@users.noreply.github.com>
Date: Sun, 22 Mar 2026 10:40:08 -0300
Subject: [PATCH] wolfssl: add new Fedora certificate path

---
 src/ssl_load.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ssl_load.c b/src/ssl_load.c
index 24c8af1..d5a7166 100644
--- a/src/ssl_load.c
+++ b/src/ssl_load.c
@@ -3142,6 +3142,7 @@ static const char* systemCaDirs[] = {
 #if defined(__ANDROID__) || defined(ANDROID)
     "/system/etc/security/cacerts"      /* Android */
 #else
+    "/etc/pki/ca-trust/extracted/pem",  /* Fedora */
     "/etc/ssl/certs",                   /* Debian, Ubuntu, Gentoo, others */
     "/etc/pki/ca-trust/source/anchors", /* Fedora, RHEL */
     "/etc/pki/tls/certs"                /* Older RHEL */
-- 
