From 79705011be71e97d7709f79f7c77589b7841fb82 Mon Sep 17 00:00:00 2001
From: Phantom X <PhantomX@users.noreply.github.com>
Date: Sat, 10 Feb 2024 21:50:07 -0300
Subject: [PATCH] Use system libzstd

---
 CMakeLists.txt | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 335133e..0bf401b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -63,12 +63,19 @@ endif()
 
 # zstd
 if (WITH_SYSTEM_ZSTD)
-  find_package(zstd REQUIRED)
+  find_package(zstd)
+  if(zstd_FOUND)
   if(TARGET zstd::libzstd_shared)
     list(APPEND PLATFORM_LIBS zstd::libzstd_shared)
   else()
     list(APPEND PLATFORM_LIBS zstd::libzstd_static)
   endif()
+  else()
+    include(FindPkgConfig)
+    pkg_check_modules(ZSTD REQUIRED libzstd)
+    list(APPEND CHDR_INCLUDES ${ZSTD_INCLUDE_DIRS})
+    list(APPEND CHDR_LIBS ${ZSTD_LIBRARIES})
+  endif()
   list(APPEND CHDR_DEFINES CHDR_SYSTEM_ZSTD)
 else()
   if(NOT TARGET zstd)
-- 
