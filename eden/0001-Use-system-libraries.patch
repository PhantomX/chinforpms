From 6dada0eb7de85d4a54c865826a1af9b13a8edf34 Mon Sep 17 00:00:00 2001
From: Phantom X <PhantomX@users.noreply.github.com>
Date: Tue, 9 Sep 2025 18:48:43 -0300
Subject: [PATCH] Use system libraries

---
 CMakeLists.txt                   | 44 ++++++++++++++++++++++++--------
 externals/CMakeLists.txt         | 29 +++++++++++++++------
 externals/ffmpeg/CMakeLists.txt  |  5 ++++
 externals/nx_tzdb/CMakeLists.txt |  2 +-
 src/dynarmic/CMakeLists.txt      |  7 -----
 5 files changed, 61 insertions(+), 26 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 42717c4..a17fd6d 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -381,12 +381,13 @@ set(ENABLE_TESTING OFF)
 # boost
 set(BOOST_INCLUDE_LIBRARIES algorithm icl pool container heap asio headers process filesystem crc variant)
 
-AddJsonPackage(boost)
+find_package(Boost 1.57.0 CONFIG REQUIRED OPTIONAL_COMPONENTS headers context system fiber filesystem)
 
 # really annoying thing where boost::headers doesn't work with cpm
 # TODO(crueter) investigate
 set(BOOST_NO_HEADERS ${Boost_ADDED})
 
+if (PATCH_ENABLED)
 if (Boost_ADDED)
     if (MSVC OR ANDROID)
         add_compile_definitions(YUZU_BOOST_v1)
@@ -406,19 +407,20 @@ if (Boost_ADDED)
         )
     endif()
 endif()
+endif()
 
 # fmt
-AddJsonPackage(fmt)
+find_package(fmt 8)
 
 # lz4
-AddJsonPackage(lz4)
+find_package(lz4 REQUIRED)
 
 if (lz4_ADDED)
     add_library(lz4::lz4 ALIAS lz4_static)
 endif()
 
 # zstd
-AddJsonPackage(zstd)
+find_package(zstd 1.5 REQUIRED MODULE)
 
 if (zstd_ADDED)
     add_library(zstd::zstd ALIAS libzstd_static)
@@ -427,17 +429,17 @@ endif()
 
 if (NOT YUZU_STATIC_ROOM)
     # nlohmann
-    AddJsonPackage(nlohmann)
+    find_package(nlohmann_json 3.8 REQUIRED)
 
     # zlib
-    AddJsonPackage(zlib)
+    find_package(ZLIB 1.2 REQUIRED)
 
     if (ZLIB_ADDED)
         add_library(ZLIB::ZLIB ALIAS zlibstatic)
     endif()
 
     # Opus
-    AddJsonPackage(opus)
+    find_package(Opus 1.3 MODULE REQUIRED)
 
     if (Opus_ADDED)
         if (MSVC AND CXX_CLANG)
@@ -453,7 +455,7 @@ if (NOT YUZU_STATIC_ROOM)
 endif()
 
 if(NOT TARGET Boost::headers)
-    AddJsonPackage(boost_headers)
+    add_subdirectory(externals/boost-headers)
 endif()
 
 # List of all FFmpeg components required
@@ -512,22 +514,39 @@ add_subdirectory(externals)
 # pass targets from externals
 # TODO(crueter): CPMUtil Propagate func?
 find_package(enet)
-find_package(unordered_dense REQUIRED)
+find_package(unordered_dense)
 
 if (ARCHITECTURE_x86 OR ARCHITECTURE_x86_64)
     find_package(xbyak)
+    if (NOT TARGET xbyak::xbyak)
+      add_subdirectory(externals/xbyak)
+    endif()
 endif()
 
 if (NOT YUZU_STATIC_ROOM)
     find_package(libusb)
     find_package(VulkanMemoryAllocator)
     find_package(VulkanUtilityLibraries)
+    find_package(VulkanHeaders 1.4.317 REQUIRED)
     find_package(SimpleIni)
     find_package(SPIRV-Tools)
     find_package(sirit)
     find_package(gamemode)
     find_package(frozen)
 
+    if(fmt_FOUND)
+        message(STATUS "Using the system fmt")
+    else()
+        add_subdirectory("externals/fmt" EXCLUDE_FROM_ALL)
+    endif()
+
+    if(unordered_dense_FOUND)
+        message(STATUS "Using the system unordered_dense")
+    else()
+        set(UNORDERED_DENSE_INSTALL OFF)
+        add_subdirectory(externals/unordered-dense)
+    endif()
+
     if (ARCHITECTURE_riscv64)
         find_package(biscuit)
     endif()
@@ -637,7 +656,12 @@ if (ENABLE_QT)
     ## Qt Externals ##
 
     # QuaZip
-    AddJsonPackage(quazip)
+    find_package(PkgConfig REQUIRED)
+    pkg_check_modules(quazip IMPORTED_TARGET quazip1-qt6)
+    message(STATUS "Using the system Quazip")
+    add_library(quazip INTERFACE)
+    target_link_libraries(quazip INTERFACE PkgConfig::quazip)
+    add_library(QuaZip::QuaZip ALIAS quazip)
 endif()
 
 if (NOT YUZU_STATIC_ROOM AND NOT (YUZU_USE_BUNDLED_FFMPEG OR YUZU_USE_EXTERNAL_FFMPEG))
diff --git a/externals/CMakeLists.txt b/externals/CMakeLists.txt
index 00bdf10..fa49360 100644
--- a/externals/CMakeLists.txt
+++ b/externals/CMakeLists.txt
@@ -26,6 +26,7 @@ set(BUILD_SHARED_LIBS OFF)
 set_directory_properties(PROPERTIES EXCLUDE_FROM_ALL ON)
 
 # Xbyak
+if (PATCH_ENABLED)
 if (ARCHITECTURE_x86 OR ARCHITECTURE_x86_64)
     AddJsonPackage(xbyak)
 endif()
@@ -40,6 +41,7 @@ endif()
 if (NOT TARGET enet::enet)
     add_library(enet::enet ALIAS enet)
 endif()
+endif()
 
 # stb
 add_library(stb stb/stb_dxt.cpp)
@@ -59,9 +61,6 @@ if (NOT TARGET LLVM::Demangle)
     add_library(LLVM::Demangle ALIAS demangle)
 endif()
 
-# unordered_dense
-AddJsonPackage(unordered-dense)
-
 if (YUZU_STATIC_ROOM)
     return()
 endif()
@@ -76,11 +75,13 @@ if (ARCHITECTURE_riscv64)
     AddJsonPackage(biscuit)
 endif()
 
+if (PATCH_ENABLED)
 # Vulkan stuff
 AddDependentPackages(vulkan-headers vulkan-utility-libraries)
 
 # frozen
 AddJsonPackage(frozen)
+endif()
 
 # DiscordRPC
 if (USE_DISCORD_PRESENCE)
@@ -97,8 +98,9 @@ if (USE_DISCORD_PRESENCE)
 endif()
 
 # SimpleIni
-AddJsonPackage(simpleini)
+add_subdirectory(simpleini)
 
+if (PATCH_ENABLED)
 # Most linux distros don't package cubeb, so enable regardless of cpm settings
 if(ENABLE_CUBEB)
     AddJsonPackage(cubeb)
@@ -128,6 +130,7 @@ if(ENABLE_CUBEB)
         add_library(cubeb::cubeb ALIAS cubeb)
     endif()
 endif()
+endif()
 
 if (NOT ANDROID)
     if (YUZU_USE_EXTERNAL_SDL2)
@@ -172,9 +175,10 @@ endif()
 set(BUILD_SHARED_LIBS OFF)
 
 # SPIRV Headers
-AddJsonPackage(spirv-headers)
+find_package(SPIRV-Headers 1.3.274 REQUIRED)
 
 # Sirit
+if (PATCH_ENABLED)
 if (YUZU_USE_BUNDLED_SIRIT)
     AddJsonPackage(sirit-ci)
 else()
@@ -188,6 +192,7 @@ endif()
 
 # SPIRV Tools
 AddJsonPackage(spirv-tools)
+endif()
 
 if (SPIRV-Tools_ADDED)
     add_library(SPIRV-Tools::SPIRV-Tools ALIAS SPIRV-Tools-static)
@@ -196,7 +201,7 @@ endif()
 
 # Catch2
 if (YUZU_TESTS OR DYNARMIC_TESTS)
-    AddJsonPackage(catch2)
+    find_package(catch2)
 endif()
 
 # getopt
@@ -208,6 +213,7 @@ endif()
 add_subdirectory(glad)
 
 # libusb
+if (PATCH_ENABLED)
 if (ENABLE_LIBUSB)
     add_subdirectory(libusb)
 endif()
@@ -226,13 +232,18 @@ if (VulkanMemoryAllocator_ADDED)
         )
     endif()
 endif()
+endif()
 
 # httplib
-AddJsonPackage(httplib)
+set(HTTPLIB_REQUIRE_OPENSSL ON)
+add_subdirectory(cpp-httplib)
 
 # cpp-jwt
 if (ENABLE_WEB_SERVICE OR ENABLE_UPDATE_CHECKER)
-    AddJsonPackage(cpp-jwt)
+    set(CPP_JWT_BUILD_EXAMPLES OFF)
+    set(CPP_JWT_BUILD_TESTS OFF)
+    set(CPP_JWT_USE_VENDORED_NLOHMANN_JSON OFF)
+    add_subdirectory(cpp-jwt)
 endif()
 
 # FFMpeg
@@ -267,6 +278,7 @@ if (ANDROID AND ARCHITECTURE_arm64)
     AddJsonPackage(libadrenotools)
 endif()
 
+if (PATCH_ENABLED)
 AddJsonPackage(gamemode)
 
 if (gamemode_ADDED)
@@ -274,6 +286,7 @@ if (gamemode_ADDED)
     target_include_directories(gamemode INTERFACE ${gamemode_SOURCE_DIR}/lib)
     add_library(gamemode::headers ALIAS gamemode)
 endif()
+endif()
 
 # Breakpad
 # TODO(crueter): Breakpad needs additional fetches
diff --git a/externals/ffmpeg/CMakeLists.txt b/externals/ffmpeg/CMakeLists.txt
index 3140f8e..2258aa1 100644
--- a/externals/ffmpeg/CMakeLists.txt
+++ b/externals/ffmpeg/CMakeLists.txt
@@ -152,10 +152,15 @@ else()
         message(FATAL_ERROR "Required program `autoconf` not found.")
     endif()
 
+  if (PATCH_ENABLED)
     AddJsonPackage(ffmpeg)
 
     set(FFmpeg_PREFIX ${ffmpeg_SOURCE_DIR})
     set(FFmpeg_BUILD_DIR ${ffmpeg_BINARY_DIR})
+  else()
+    set(FFmpeg_PREFIX ${PROJECT_SOURCE_DIR}/externals/ffmpeg/ffmpeg)
+    set(FFmpeg_BUILD_DIR ${PROJECT_BINARY_DIR}/externals/ffmpeg-build)
+  endif()
     set(FFmpeg_MAKEFILE ${FFmpeg_BUILD_DIR}/Makefile)
     make_directory(${FFmpeg_BUILD_DIR})
 
diff --git a/externals/nx_tzdb/CMakeLists.txt b/externals/nx_tzdb/CMakeLists.txt
index a82bf0b..5f4a39c 100644
--- a/externals/nx_tzdb/CMakeLists.txt
+++ b/externals/nx_tzdb/CMakeLists.txt
@@ -56,7 +56,7 @@ elseif (MSVC AND NOT CXX_CLANG AND ENABLE_LTO)
             ${NX_TZDB_ARCHIVE}
         DESTINATION
             ${NX_TZDB_BASE_DIR})
-else()
+elseif (CAN_BUILD_NX_TZDB AND YUZU_DOWNLOAD_TIME_ZONE_DATA)
     message(STATUS "Downloading time zone data...")
     AddJsonPackage(tzdb)
 
diff --git a/src/dynarmic/CMakeLists.txt b/src/dynarmic/CMakeLists.txt
index dd1def5..f5d8c83 100644
--- a/src/dynarmic/CMakeLists.txt
+++ b/src/dynarmic/CMakeLists.txt
@@ -119,9 +119,6 @@ if (NOT Boost_FOUND)
     find_package(Boost 1.57 REQUIRED)
 endif()
 
-find_package(fmt 8 CONFIG)
-find_package(unordered_dense REQUIRED)
-
 if ("arm64" IN_LIST ARCHITECTURE OR DYNARMIC_TESTS)
     find_package(oaknut 2.0.1 CONFIG)
 endif()
@@ -130,10 +127,6 @@ if ("riscv" IN_LIST ARCHITECTURE)
     find_package(biscuit 0.9.1 REQUIRED)
 endif()
 
-if ("x86_64" IN_LIST ARCHITECTURE)
-    find_package(xbyak 7 CONFIG)
-endif()
-
 if (DYNARMIC_USE_LLVM)
     find_package(LLVM REQUIRED)
     separate_arguments(LLVM_DEFINITIONS)
-- 
2.53.0

