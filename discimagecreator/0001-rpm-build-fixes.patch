From 8ec772f15e610312d2ed913360540fa01dbecf78 Mon Sep 17 00:00:00 2001
From: Phantom X <PhantomX@users.noreply.github.com>
Date: Fri, 20 Mar 2026 17:36:00 -0300
Subject: [PATCH] rpm build fixes

---
 DiscImageCreator/execScsiCmdforCDCheck.cpp |  2 +-
 DiscImageCreator/get.cpp                   |  2 +-
 DiscImageCreator/xml.h                     |  2 +-
 meson.build                                | 13 +++----------
 4 files changed, 6 insertions(+), 13 deletions(-)

diff --git a/DiscImageCreator/execScsiCmdforCDCheck.cpp b/DiscImageCreator/execScsiCmdforCDCheck.cpp
index 818e33d..c7ca918 100644
--- a/DiscImageCreator/execScsiCmdforCDCheck.cpp
+++ b/DiscImageCreator/execScsiCmdforCDCheck.cpp
@@ -35,7 +35,7 @@
 #include "outputScsiCmdLogforCD.h"
 #include "set.h"
 #include "_external/NonStandardFunction.h"
-#include "_external/libunshield/libunshield.h"
+#include <libunshield.h>
 
 #ifndef min
 #define min(a,b)            (((a) < (b)) ? (a) : (b))
diff --git a/DiscImageCreator/get.cpp b/DiscImageCreator/get.cpp
index 0409836..52431ca 100644
--- a/DiscImageCreator/get.cpp
+++ b/DiscImageCreator/get.cpp
@@ -567,7 +567,7 @@ BOOL GetEccEdcCmd(
 #ifdef _WIN32
 	BOOL bRet = GetCmd(szPathForEcc, _T("EccEdc"), _T("exe"));
 #else
-	BOOL bRet = GetCmd(szPathForEcc, _T("./EccEdc"), _T(".out"));
+	BOOL bRet = GetCmd(szPathForEcc, _T("_RPM_BIN_DIR_/EccEdc"), _T(".out"));
 #endif
 	if (bRet && PathFileExists(szPathForEcc)) {
 		if (!_tcscmp(pszCmd, _T("check"))) {
diff --git a/DiscImageCreator/xml.h b/DiscImageCreator/xml.h
index 515e33b..4f3a488 100644
--- a/DiscImageCreator/xml.h
+++ b/DiscImageCreator/xml.h
@@ -15,7 +15,7 @@
  */
 #pragma once
 #ifndef _WIN32
-#include "_external/tinyxml2.h"
+#include <tinyxml2.h>
 using namespace tinyxml2;
 #endif
 
diff --git a/meson.build b/meson.build
index f2bb298..ad9a1f2 100644
--- a/meson.build
+++ b/meson.build
@@ -12,13 +12,15 @@ if target_machine.system() in ['linux', 'darwin']
   build_date = run_command('date', '+%Y%m%d').stdout().strip()
   build_time = run_command('date', '+%H%M%S').stdout().strip()
   libarchive_dep = dependency('libarchive', required: true, method: 'pkg-config')
+  libunshield_dep = dependency('libunshield', required: true, method: 'pkg-config')
+  tinyxml2_dep = dependency('tinyxml2', required: true, method: 'pkg-config')
   zlib_dep = dependency('zlib', required: true, method: 'pkg-config')
   openssl_dep = dependency('openssl', required: true, method: 'pkg-config')
   add_project_arguments('-include', 'defineForLinux.h', language : 'cpp')
   inc = [include_directories('DiscImageCreator/'), include_directories('DiscImageCreator/_external'), include_directories('DiscImageCreator/_linux')]
 endif
 
-deps = [libarchive_dep, zlib_dep, openssl_dep]
+deps = [libarchive_dep, libunshield_dep, zlib_dep, openssl_dep, tinyxml2_dep]
 
 if host_machine.system() == 'darwin'
   applefw_dep = dependency(
@@ -58,16 +60,7 @@ executable(
     'DiscImageCreator/_external/sha1.c',
     'DiscImageCreator/_external/sha224-256.c',
     'DiscImageCreator/_external/sha384-512.c',
-    'DiscImageCreator/_external/tinyxml2.cpp',
     'DiscImageCreator/_external/xxhash.c',
-    'DiscImageCreator/_external/libunshield/component.c',
-    'DiscImageCreator/_external/libunshield/converter.c',
-    'DiscImageCreator/_external/libunshield/directory.c',
-    'DiscImageCreator/_external/libunshield/file.c',
-    'DiscImageCreator/_external/libunshield/file_group.c',
-    'DiscImageCreator/_external/libunshield/helper.c',
-    'DiscImageCreator/_external/libunshield/libunshield.c',
-    'DiscImageCreator/_external/libunshield/log.c',
     'DiscImageCreator/_external/ps3auth/auth_service.c',
     'DiscImageCreator/_external/ps3auth/crypto_backend_openssl.c',
     'DiscImageCreator/_external/ps3auth/data_unwrap.c',
-- 
