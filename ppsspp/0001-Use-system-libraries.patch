diff --git a/CMakeLists.txt b/CMakeLists.txt
index ea57576..826d3fc 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1266,6 +1266,15 @@ else()
 	set(LIBZIP_LIBRARY libzip)
 endif()
 
+find_package(PkgConfig QUIET)
+pkg_search_module(7zip IMPORTED_TARGET lzmasdk-c)
+if(7zip_FOUND)
+	message(STATUS "Using the system 7zip")
+	add_library(7zip INTERFACE)
+	include_directories(${7zip_INCLUDE_DIRS})
+	add_compile_definitions(SHARED_7ZIP)
+	target_link_libraries(7zip INTERFACE PkgConfig::7zip)
+else()
 add_library(7zip STATIC
 	ext/lzma-sdk/7zArcIn.c
 	ext/lzma-sdk/7zBuf.c
@@ -1283,6 +1292,7 @@ add_library(7zip STATIC
 )
 target_link_libraries(7zip)
 include_directories(ext/lzma-sdk)
+endif()
 set(LIB7ZIP_LIBRARY 7zip)
 
 # Arm platforms require at least libpng17.
@@ -1772,11 +1782,18 @@ add_library(xbrz STATIC
 )
 target_include_directories(xbrz PRIVATE ext/xbrz)
 
+pkg_search_module(xxhash IMPORTED_TARGET libxxhash)
+if(xxhash_FOUND)
+	message(STATUS "Using the system libxxhash")
+	add_library(xxhash INTERFACE)
+	target_link_libraries(xxhash INTERFACE PkgConfig::xxhash)
+else()
 add_library(xxhash STATIC
 	ext/xxhash.c
 	ext/xxhash.h
 )
-target_include_directories(xxhash PRIVATE ext/xxhash)
+target_include_directories(xxhash PRIVATE ext)
+endif()
 
 set(CoreExtra)
 set(CoreExtraLibs)
@@ -2604,6 +2621,14 @@ if(OPENGL_opengl_LIBRARY AND OpenGL_GL_PREFERENCE STREQUAL GLVND AND NOT APPLE)
 	set(OPENGL_LIBRARIES OpenGL::OpenGL)
 endif()
 
+find_package(RapidJSON)
+if(rapidjson_FOUND)
+	message(STATUS "Using the system rapidjson")
+	target_include_directories(${CoreLibName} PRIVATE ${RAPIDJSON_INCLUDE_DIRS})
+else()
+	target_include_directories(${CoreLibName} PRIVATE ext/rapidjson/include)
+endif()
+
 if(USE_SYSTEM_ZSTD)
 	find_package(ZSTD REQUIRED)
 	target_include_directories(${CoreLibName} PRIVATE ${ZSTD_INCLUDE_DIR})
